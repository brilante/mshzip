{
  "name": "msh-zip",
  "version": "2.0.1",
  "description": "Fixed-chunk dedup + entropy compression with ECC protection and C native acceleration (MSH1 format)",
  "main": "lib/index.js",
  "bin": {
    "mshzip": "cli.js"
  },
  "files": [
    "lib/",
    "cli.js"
  ],
  "scripts": {
    "pack": "node cli.js pack",
    "unpack": "node cli.js unpack",
    "info": "node cli.js info",
    "test": "node test/benchmark.js"
  },
  "keywords": [
    "compression",
    "dedup",
    "deduplication",
    "binary",
    "msh",
    "gzip",
    "streaming",
    "chunk",
    "sha256",
    "ecc",
    "hamming",
    "error-correction",
    "coorddict",
    "bitdict"
  ],
  "author": "brilante33",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brilante/mshzip.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
